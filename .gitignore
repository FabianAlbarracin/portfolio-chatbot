# =========================
# SECRETOS Y CONFIGURACIÓN
# =========================
.env
secretos/
*.pem
*.key

# =========================
# BASES DE DATOS VECTORIALES Y DATOS LOCALES
# =========================
# No subas ChromaDB, pesa mucho y los embeddings se pueden regenerar
data/chroma_db/
*.sqlite3
*.db
*.log

# =========================
# CACHÉ DE PYTHON
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so

# =========================
# ENTORNOS VIRTUALES (Si usas alguno fuera de Docker)
# =========================
venv/
env/
.venv/

# =========================
# ARCHIVOS DEL SISTEMA OPERATIVO
# =========================
.DS_Store
Thumbs.db

# =========================
# ARCHIVOS PERSONALES Y DE PORTAFOLIO
# =========================
# Ignorar todos los documentos Markdown con información personal
data/**/*.md
data/*.md

# =========================
# LOGS Y RASTREO DE USUARIOS
# =========================
*.log
data/usage_logs.json