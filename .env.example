# ============================================
# REQUERIDAS
# ============================================

# Virtual key generada en LiteLLM (http://litellm:4000)
LITELLM_CHATBOT_KEY=sk-tu-virtual-key-aqui

# API key para proteger POST /admin/refresh
CHATBOT_API_KEY=cambia-esta-key-secreta

# ============================================
# OPCIONALES (con defaults)
# ============================================

# Origenes CORS permitidos (separados por coma)
ALLOWED_ORIGINS=localhost:5173

# Hot-reload uvicorn para desarrollo (true/false)
UVICORN_RELOAD=false

# Nivel de logging Python (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Rate limiting
DAILY_REQUEST_LIMIT=100
RATE_LIMIT_PER_MINUTE=20

# TTL de sesion en segundos (10 minutos)
SESSION_TTL_SECONDS=600

# ============================================
# SOLO PARA TESTS
# ============================================

# API key directa de Groq para el evaluador (no usada en produccion)
# GROQ_API_KEY=gsk_tu-key-de-groq
